generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  PENDING_TRAINER
  STUDENT
  TRAINER
  INSTITUTION
  PROGRAMME_MANAGER
  MONITORING_OFFICER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

model User {
  id            String   @id @default(uuid())
  clerkUserId   String?  @unique
  email         String?  @unique
  password      String?
  name          String
  role          Role
  institutionId String?

  institution   Institution? @relation(fields: [institutionId], references: [id])
  createdInstitutions Institution[] @relation("InstitutionCreator")

  batchTrainers BatchTrainer[]
  batchStudents BatchStudent[]
  createdInvites Invite[]
  sessions      Session[]
  attendance    Attendance[]
  approvedTrainerRequests TrainerRequest[] @relation("TrainerRequestApprover")
  trainerRequests TrainerRequest[] @relation("TrainerRequestRequester")
  auditLogs       AuditLog[]      @relation("AuditActor")

  createdAt     DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  actorRole Role?
  eventType String
  entityType String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([eventType])
  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model Institution {
  id                    String   @id @default(uuid())
  name                  String
  createdBySuperAdminId String
  createdAt             DateTime @default(now())

  superAdmin User @relation("InstitutionCreator", fields: [createdBySuperAdminId], references: [id])
  users      User[]
  batches    Batch[]
  trainerRequests TrainerRequest[]
}

model Batch {
  id            String   @id @default(uuid())
  name          String
  institutionId String

  institution   Institution @relation(fields: [institutionId], references: [id])

  trainers      BatchTrainer[]
  students      BatchStudent[]
  invites       Invite[]
  sessions      Session[]

  createdAt     DateTime @default(now())
}

model TrainerRequest {
  id            String   @id @default(uuid())
  requesterId   String
  institutionId String
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime @default(now())

  requester   User        @relation("TrainerRequestRequester", fields: [requesterId], references: [id])
  institution Institution @relation(fields: [institutionId], references: [id])
  approver    User?       @relation("TrainerRequestApprover", fields: [approvedById], references: [id])

  @@unique([requesterId, institutionId])
}

model Invite {
  id        String   @id @default(uuid())
  token     String   @unique
  batchId   String
  createdBy String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  batch       Batch @relation(fields: [batchId], references: [id])
  creatorUser User  @relation(fields: [createdBy], references: [id])
}

model BatchTrainer {
  batchId   String
  trainerId String

  batch     Batch @relation(fields: [batchId], references: [id])
  trainer   User  @relation(fields: [trainerId], references: [id])

  @@id([batchId, trainerId])
}

model BatchStudent {
  batchId   String
  studentId String

  batch     Batch @relation(fields: [batchId], references: [id])
  student   User  @relation(fields: [studentId], references: [id])

  @@id([batchId, studentId])
}

model Session {
  id         String      @id @default(uuid())
  batchId    String
  trainerId  String
  title      String
  date       DateTime
  startTime  DateTime
  endTime    DateTime

  batch      Batch       @relation(fields: [batchId], references: [id])
  trainer    User        @relation(fields: [trainerId], references: [id])

  attendance Attendance[]

  createdAt  DateTime    @default(now())
}

model Attendance {
  id        String           @id @default(uuid())
  sessionId String
  studentId String
  status    AttendanceStatus
  markedAt  DateTime         @default(now())

  session   Session          @relation(fields: [sessionId], references: [id])
  student   User             @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
}
